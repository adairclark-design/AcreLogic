# seed-scanner/.env.example
# Copy to .env for local testing. Set all of these in Railway variables.

# Neon Postgres connection string
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Gemini API key for price extraction
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Admin secret to protect POST /api/seeds/scan endpoint
# Set to any strong random string — used as X-Admin-Secret header
ADMIN_SECRET=change-me-to-something-secure

# Port (Railway sets this automatically — leave as 8080 for local)
PORT=8080
