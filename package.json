{
  "name": "acrelogic",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:pwa": "TMPDIR=/tmp/acrelogic-metro-cache EXPO_NO_CACHE=1 expo export -p web && node scripts/pwa-inject.js",
    "pwa:inject": "node scripts/pwa-inject.js",
    "deploy": "npm run build:pwa && wrangler pages deploy dist --project-name acrelogic-preview --commit-dirty=true",
    "wrangler:login": "wrangler login"
  },
  "dependencies": {
    "@expo/fingerprint": "^0.16.5",
    "@expo/metro-runtime": "~3.2.3",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/stack": "^6.3.29",
    "eas-cli": "^18.1.0",
    "expo": "~51.0.0",
    "expo-file-system": "^55.0.10",
    "expo-image": "~1.12.15",
    "expo-linear-gradient": "~13.0.2",
    "expo-print": "^55.0.8",
    "expo-sharing": "^55.0.11",
    "expo-sqlite": "^55.0.10",
    "expo-status-bar": "~1.12.1",
    "expo-updates": "^0.25.28",
    "konva": "^10.2.0",
    "react": "18.2.0",
    "react-dom": "^18.2.0",
    "react-konva": "^19.2.3",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.1",
    "react-native-web": "^0.19.13",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "wrangler": "^4.71.0"
  },
  "private": true
}