{
  "name": "acrelogic",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "node node_modules/@expo/cli/build/bin/cli start -c --web",
    "build:web": "expo export --platform web",
    "build:pwa": "npm_config_cache=/tmp/npm-cache npx expo export -p web && cp -r public/crops dist/crops && node scripts/pwa-inject.js",
    "build:cloudflare": "npm run build:pwa",
    "pwa:inject": "node scripts/pwa-inject.js",
    "deploy": "npm run build:pwa && wrangler pages deploy dist --project-name acrelogic --commit-dirty=true",

    "wrangler:login": "wrangler login"
  },
  "dependencies": {
    "@expo/fingerprint": "^0.10.1",
    "@expo/metro-runtime": "~3.2.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/stack": "^6.3.29",
    "expo": "~51.0.39",
    "expo-file-system": "~17.0.1",
    "expo-image": "~1.12.15",
    "expo-linear-gradient": "~13.0.2",
    "expo-print": "~13.0.1",
    "expo-sharing": "~12.0.1",
    "expo-sqlite": "~14.0.6",
    "expo-status-bar": "~1.12.1",
    "expo-updates": "~0.25.27",
    "konva": "^9.3.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-konva": "18.2.10",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.1",
    "react-native-web": "~0.19.10",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "wrangler": "^3.0.0"
  },
  "private": true
}